-- Migration from schema version 2 to 3
-- Adds cloud sync tracking columns to ReportEntity.
-- Both columns are safe to add with ALTER TABLE ADD COLUMN:
--   synced_at: nullable INTEGER (no NOT NULL constraint)
--   sync_failure_count: INTEGER with DEFAULT 0 (valid ADD COLUMN target)
ALTER TABLE ReportEntity ADD COLUMN synced_at INTEGER;
ALTER TABLE ReportEntity ADD COLUMN sync_failure_count INTEGER NOT NULL DEFAULT 0;
